{
  "name": "tree-sitter-gta3",
  "version": "1.0.0",
  "description": "Tree-sitter grammar for GTA Sanny Builder scripts",
  "type": "module",
  "main": "index.js",
  "keywords": [
    "gta3",
    "sanny-builder",
    "tree-sitter",
    "parser",
    "grammar",
    "wasm",
    "webassembly"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "tree-sitter-cli": "^0.26.8"
  },
  "scripts": {
    "build": "npm run generate && tree-sitter build --wasm",
    "build:debug": "tree-sitter build --wasm --debug",
    "test": "tree-sitter test",
    "test:deno": "deno run --allow-read ./examples/deno.ts",
    "generate": "tree-sitter generate"
  },
  "tree-sitter": [
    {
      "scope": "source.gta3",
      "path": ".",
      "file-types": [
        "txt"
      ]
    }
  ]
}
